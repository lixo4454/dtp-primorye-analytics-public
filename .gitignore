# Streamlit
.streamlit/secrets.toml

# ─── data/raw/ — большие исходники, кэши, временные файлы ─────────
# По умолчанию игнорируем ВСЁ в data/raw/, явно включаем только
# нужное (справочники, .gitkeep).
data/raw/**

# Но не игнорируем сами папки (чтобы исключения работали)
!data/raw/
!data/raw/**/

# Исключения — что коммитим явно
!data/raw/.gitkeep
!data/raw/vehicle_brand_steering.csv
!data/raw/primorye_admin_boundary_osm.geojson
!data/raw/primorye_land_polygons.geojson

# ─── data/processed/ ──────────────────────────────────────────────
# По умолчанию игнорируем сгенерированные большие данные
data/processed/*.html
data/processed/*.jsonl
data/processed/*.json
data/processed/*.geojson
data/processed/*.pkl
data/processed/*.npz

# Но включаем явно: артефакты-визуализации и документационные референсы
!data/processed/.gitkeep
!data/processed/*.png
# Smoke-ответы FastAPI — фактические выходы 11 эндпоинтов как
# documentation reference; ~50 КБ, не регенерируются ежедневно
!data/processed/api_smoke_responses.json
# CatBoost form schema — медиана/мода train для дефолтов
# Streamlit-формы; 8.6 КБ, регенерируется через build_catboost_form_schema.py
!data/processed/catboost_form_schema.json

# ─── models/ — обученные ML-модели (большие, регенерируются скриптами) ─
models/*
!models/.gitkeep

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Claude Code (служебные файлы агента — настройки/кэш для конкретного клиента)
.claude/

# Локальные логи скриптов (Optuna, обучение моделей и т.п.)
logs/
